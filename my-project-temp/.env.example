# Apical — environment variables.
# Copy to .env.local for local dev, or set these in the Vercel dashboard.
# NEVER commit real secrets. Only this example file is tracked.

# ----------------------------------------------------------------------------
# Required (production)
# ----------------------------------------------------------------------------

# Postgres runtime connection — Supabase Transaction pooler (port 6543):
#   postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=

# Direct/session connection for migrations & `prisma db push` (port 5432):
#   postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres
DIRECT_URL=

# Supabase Auth (Project Settings -> API).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Pre-launch passcode gate. When set, visitors must enter this passcode once
# per browser before they can see the app. Leave empty to disable the gate.
PRELAUNCH_PASSCODE=

# AES-256-GCM key for the credential/PAT vault. Use a random 32+ char string.
APICAL_VAULT_KEY=

# Disable the local auth bypass in production.
AUTH_BYPASS_DEV=false

# ----------------------------------------------------------------------------
# AI models (at least one provider needed for agents to respond)
# ----------------------------------------------------------------------------
OPENAI_API_KEY=
# OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
GOOGLE_API_KEY=
XAI_API_KEY=
# LLM_DEFAULT_PROVIDER=

# ----------------------------------------------------------------------------
# Optional — Google OAuth (web login button). Configure the redirect in
# Supabase Auth -> Providers -> Google, not here.
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# Optional — Stripe billing (demo mode works without these)
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PERSONAL=
# STRIPE_PRICE_TEAM=
# STRIPE_PRICE_ENTERPRISE=
# BILLING_DEMO_MODE=

# ----------------------------------------------------------------------------
# Optional — email (password reset / notifications). Empty = log-only.
# ----------------------------------------------------------------------------
SMTP_URI=
NOTIFICATIONS_FROM_EMAIL=

# ----------------------------------------------------------------------------
# Desktop / NextAuth legacy (only used by the Tauri desktop build locally)
# ----------------------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=
