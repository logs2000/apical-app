{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the Apical desktop windows (main + popped-out secondary windows).",
  "windows": ["main", "apical-*"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    "http:default",
    "dialog:default",
    "fs:default",
    "os:default",
    "process:default",
    "notification:default",
    "global-shortcut:default"
  ]
}
