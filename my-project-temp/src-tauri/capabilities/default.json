{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the Apical desktop windows (main + popped-out secondary windows).",
  "windows": ["main", "apical-*"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "node",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "http:default",
    "dialog:default",
    "fs:default",
    "os:default",
    "process:default",
    "notification:default",
    "global-shortcut:default"
  ]
}
