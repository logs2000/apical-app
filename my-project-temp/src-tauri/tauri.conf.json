{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Apical",
  "version": "0.1.0",
  "identifier": "dev.apical.desktop",
  "build": {
    "beforeDevCommand": "bash scripts/ensure-prod-server.sh",
    "devUrl": "http://127.0.0.1:3000/api/auth/desktop-ui",
    "beforeBuildCommand": "bash scripts/fetch-node-sidecar.sh && bash scripts/prepare-tauri-bundle.sh",
    "frontendDist": "../src-tauri/app-dist"
  },
  "app": {
    "windows": [
      {
        "title": "Apical",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Visible",
        "visible": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["bundle-resources/standalone"],
    "externalBin": ["binaries/node"],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "Apical — AI runtime for arbitrary APIs/MCP servers.",
    "longDescription": "Apical is a runtime that authenticates against and invokes arbitrary APIs and MCP servers. AI supplies discovery, invocation glue, and response normalization. The durable engineering is auth, the credential vault, and triggers.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": ["English"]
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "shell": {
      "open": true,
      "sidecar": true,
      "scope": [
        {
          "name": "binaries/node",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}
